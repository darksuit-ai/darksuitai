# Copy this file to `.env` in your project root and fill in the keys you use.
# DarkSuitAI's darksuitai.LoadEnv() loads this file so os.Getenv can see it.
# (Go does not read .env automatically.)  Never commit your real .env.

# Which provider the example (doc/main.go) uses: anthropic | openai | gemini | groq
DARKSUIT_PROVIDER=anthropic

# Provider API keys (set the one(s) you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional: telemetry
LANGSMITH_API_KEY=

# Optional: embeddings for semantic memory (OpenAI-compatible)
# Uses OPENAI_API_KEY by default.

# Optional: MongoDB for persistent chat memory / summaries / vectors
MONGODB_URI=
